@page "/register"
@layout EmptyLayout
@inject ApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using MudBlazor
@using TMS.Application.DTOs.Auth
@using TMS.Domain.Enums
@using TMS.Web.Services

<style>
    .reg-root {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        background: #0A0C10;
    }

    @@media (max-width: 960px) {
        .reg-root {
            grid-template-columns: 1fr;
        }

        .reg-brand-panel {
            display: none !important;
        }
    }

    .reg-brand-panel {
        position: relative;
        background: #0F1117;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 48px;
        overflow: hidden;
        border-right: 1px solid #1E2130;
    }

    .reg-brand-grid {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(139,92,246,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(139,92,246,0.06) 1px, transparent 1px);
        background-size: 40px 40px;
    }

    .reg-brand-glow {
        position: absolute;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(139,92,246,0.12) 0%, transparent 70%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        pointer-events: none;
    }

    .reg-step-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 20px 0;
        border-bottom: 1px solid #1E2130;
        position: relative;
        z-index: 1;
    }

    .reg-step-num {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(99,102,241,0.15);
        border: 1px solid rgba(99,102,241,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 13px;
        font-weight: 700;
        color: #6366F1;
    }

    .reg-form-panel {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
        background: #0A0C10;
        overflow-y: auto;
    }

    .reg-form-box {
        width: 100%;
        max-width: 500px;
        padding: 8px 0;
    }

    .reg-field-label {
        font-size: 13px;
        font-weight: 500;
        color: #9CA3AF;
        margin-bottom: 6px;
        display: block;
    }

    .reg-role-card {
        border: 1px solid #1E2130;
        border-radius: 10px;
        padding: 14px 16px;
        cursor: pointer;
        transition: all 0.15s ease;
        display: flex;
        align-items: center;
        gap: 12px;
        background: transparent;
    }

        .reg-role-card:hover {
            border-color: #374151;
            background: rgba(255,255,255,0.02);
        }

        .reg-role-card.selected {
            border-color: #6366F1;
            background: rgba(99,102,241,0.08);
        }

    .reg-role-icon {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .reg-submit-btn {
        background: linear-gradient(135deg, #6366F1, #7C3AED) !important;
        border: none !important;
        border-radius: 10px !important;
        font-weight: 600 !important;
        height: 52px !important;
        font-size: 15px !important;
    }

    .tms-input-field {
        --mud-input-outlined-border: #1E2130;
    }
</style>

<div class="reg-root">

    <!-- ── Brand / Left Panel ───────────────────────────── -->
    <div class="reg-brand-panel">
        <div class="reg-brand-grid"></div>
        <div class="reg-brand-glow"></div>

        <!-- Logo -->
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:56px;position:relative;z-index:1;">
            <div style="width:42px;height:42px;background:linear-gradient(135deg,#6366F1,#8B5CF6);border-radius:12px;display:flex;align-items:center;justify-content:center;">
                <MudIcon Icon="@Icons.Material.Filled.School" Style="color:#fff;font-size:22px;" />
            </div>
            <div>
                <MudText Typo="Typo.subtitle1" Style="font-weight:800;color:#F9FAFB;letter-spacing:-0.3px;line-height:1;">TMS</MudText>
                <MudText Typo="Typo.caption" Style="color:#6B7280;">Tuition Management</MudText>
            </div>
        </div>

        <!-- Heading -->
        <div style="position:relative;z-index:1;margin-bottom:40px;">
            <MudText Typo="Typo.h4" Style="color:#F9FAFB;font-weight:800;line-height:1.2;letter-spacing:-0.8px;margin-bottom:12px;">
                Get started in<br />
                <span style="background:linear-gradient(90deg,#8B5CF6,#6366F1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                    three easy steps
                </span>
            </MudText>
            <MudText Typo="Typo.body2" Style="color:#6B7280;line-height:1.7;">
                Join hundreds of students and tutors already using TMS to manage their learning journey.
            </MudText>
        </div>

        <!-- Steps -->
        <div style="position:relative;z-index:1;">
            @foreach (var step in _steps)
            {
                <div class="reg-step-item">
                    <div class="reg-step-num">@step.Number</div>
                    <div>
                        <MudText Typo="Typo.body2" Style="color:#F9FAFB;font-weight:600;margin-bottom:2px;">@step.Title</MudText>
                        <MudText Typo="Typo.caption" Style="color:#6B7280;line-height:1.5;">@step.Description</MudText>
                    </div>
                </div>
            }
        </div>

        <MudText Typo="Typo.caption" Style="color:#374151;margin-top:40px;position:relative;z-index:1;display:block;">
            © @DateTime.Now.Year Tuition Management System
        </MudText>
    </div>

    <!-- ── Form / Right Panel ───────────────────────────── -->
    <div class="reg-form-panel">
        <div class="reg-form-box">

            <!-- Mobile logo -->
            <div class="d-flex d-md-none align-center justify-center gap-2 mb-8">
                <div style="width:38px;height:38px;background:linear-gradient(135deg,#6366F1,#8B5CF6);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                    <MudIcon Icon="@Icons.Material.Filled.School" Style="color:#fff;font-size:18px;" />
                </div>
                <MudText Typo="Typo.h6" Style="color:#F9FAFB;font-weight:800;">TMS Portal</MudText>
            </div>

            <!-- Header -->
            <div style="margin-bottom:36px;">
                <MudText Typo="Typo.h5" Style="color:#F9FAFB;font-weight:800;letter-spacing:-0.5px;margin-bottom:6px;">
                    Create your account
                </MudText>
                <MudText Typo="Typo.body2" Style="color:#6B7280;">
                    Fill in your details to get started with TMS
                </MudText>
            </div>

            <MudForm @ref="_form" @bind-IsValid="_isValid">

                <!-- Name row -->
                <MudGrid Spacing="3" Class="mb-1">
                    <MudItem xs="6">
                        <span class="reg-field-label">First name</span>
                        <MudTextField @bind-Value="_model.FirstName"
                                      Placeholder="John"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      FullWidth="true"
                                      Class="tms-input-field" />
                    </MudItem>
                    <MudItem xs="6">
                        <span class="reg-field-label">Last name</span>
                        <MudTextField @bind-Value="_model.LastName"
                                      Placeholder="Doe"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      FullWidth="true"
                                      Class="tms-input-field" />
                    </MudItem>
                </MudGrid>

                <!-- Email -->
                <div class="mb-1">
                    <span class="reg-field-label">Email address</span>
                    <MudTextField @bind-Value="_model.Email"
                                  Placeholder="you@school.com"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  FullWidth="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                                  Class="tms-input-field" />
                </div>

                <!-- Password -->
                <div class="mb-1">
                    <span class="reg-field-label">Password</span>
                    <MudTextField @bind-Value="_model.Password"
                                  Placeholder="Min. 8 characters"
                                  InputType="@(_showPassword? InputType.Text: InputType.Password)"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  FullWidth="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                                  Class="tms-input-field" />
                </div>

                <!-- Confirm Password -->
                <div class="mb-4">
                    <span class="reg-field-label">Confirm password</span>
                    <MudTextField @bind-Value="_confirmPassword"
                                  Placeholder="Re-enter your password"
                                  InputType="@(_showConfirm? InputType.Text: InputType.Password)"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  FullWidth="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showConfirm? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="@(() => _showConfirm = !_showConfirm)"
                                  Class="tms-input-field" />
                </div>

                <!-- Role picker -->
                <div class="mb-6">
                    <span class="reg-field-label">I am joining as…</span>
                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:4px;">
                        @foreach (var role in _roles)
                        {
                            <div class="reg-role-card @(_model.Role == role.Value ? "selected" : "")"
                                 @onclick="() => _model.Role = role.Value">
                                <div class="reg-role-icon" style="background:@role.BgColor;">
                                    <MudIcon Icon="@role.Icon" Style="@($"color:{role.IconColor};font-size:18px;")" />
                                </div>
                                <div>
                                    <MudText Typo="Typo.body2" Style="font-weight:600;color:#F9FAFB;font-size:13px;">@role.Label</MudText>
                                    <MudText Typo="Typo.caption" Style="color:#6B7280;font-size:11px;">@role.Sub</MudText>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Submit -->
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="OnRegister"
                           Disabled="_loading"
                           Class="reg-submit-btn">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Creating account...</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" Style="font-size:18px;" />
                        <span>Create account</span>
                    }
                </MudButton>
            </MudForm>

            <!-- Sign-in link -->
            <div style="margin-top:28px;text-align:center;">
                <MudText Typo="Typo.body2" Style="color:#6B7280;">
                    Already have an account?
                    <MudLink Href="/login" Color="Color.Primary" Style="font-weight:600;">Sign in</MudLink>
                </MudText>
            </div>
        </div>
    </div>
</div>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading;
    private bool _showPassword;
    private bool _showConfirm;
    private string _confirmPassword = string.Empty;

    private RegisterRequest _model = new() { Role = UserRole.Student };

    private readonly (UserRole Value, string Label, string Sub, string Icon, string BgColor, string IconColor)[] _roles = new[]
    {
        (UserRole.Student,  "Student",  "Enrolling",  Icons.Material.Filled.School,       "rgba(99,102,241,0.15)",  "#6366F1"),
        (UserRole.Tutor,    "Tutor",    "Teaching",   Icons.Material.Filled.MenuBook,     "rgba(16,185,129,0.15)",  "#10B981"),
        (UserRole.Admin,    "Admin",    "Managing",   Icons.Material.Filled.AdminPanelSettings, "rgba(245,158,11,0.15)", "#F59E0B"),
    };

    private readonly (string Number, string Title, string Description)[] _steps = new[]
    {
        ("1", "Create your account", "Fill in your personal details and choose your role to get started."),
        ("2", "Complete your profile", "Add any additional information relevant to your role."),
        ("3", "Start using TMS", "Access your dashboard and begin managing your tuition experience."),
    };

    private async Task OnRegister()
    {
        await _form.Validate();
        if (!_isValid) return;

        if (_model.Password != _confirmPassword)
        {
            Snackbar.Add("Passwords do not match.", Severity.Error);
            return;
        }

        _loading = true;

        try
        {
            Console.WriteLine($"Registering: {System.Text.Json.JsonSerializer.Serialize(_model)}");
            var result = await Api.PostAsync<object>("api/auth/register", _model);
            Console.WriteLine($"Register result: Success={result.Success}, Error={result.Error}");

            if (result.Success)
            {
                Snackbar.Add("Account created! Please sign in.", Severity.Success);
                Nav.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add(result.Error ?? "Registration failed. Please try again.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Register exception: {ex.Message}");
            Snackbar.Add("An unexpected error occurred.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
