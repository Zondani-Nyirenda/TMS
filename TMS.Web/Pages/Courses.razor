@page "/courses"
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using TMS.Application.Common
@using TMS.Application.DTOs.Course
@using TMS.Domain.Enums
@using TMS.Web.Services
@using TMS.Web.Component.Dialog

@attribute [Authorize(Roles = "Admin,Tutor,Student")]

@inject ApiClient Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Courses – TMS</PageTitle>

<div class="d-flex align-center justify-space-between mb-4 flex-wrap gap-3">
    <div>
        <MudText Typo="Typo.h5" Class="fw-bold">Courses</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Manage all offered courses</MudText>
    </div>
    <AuthorizeView Roles="Admin">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                   StartIcon="@Icons.Material.Filled.Add" 
                   OnClick="OpenCreateDialog">
            New Course
        </MudButton>
    </AuthorizeView>
</div>

<MudPaper Elevation="1" Class="pa-3 mb-4 rounded-xl">
    <div class="d-flex gap-3 flex-wrap">
        <MudTextField @bind-Value="_search" Placeholder="Search courses…" 
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined" Clearable="true" Class="flex-grow-1"
                      DebounceInterval="400" 
                      OnDebounceIntervalElapsed="@(() => RefreshCourses())" />

        <MudSelect T="string" Value="_statusFilter" Label="Status" Variant="Variant.Outlined" 
                   Style="min-width:130px" ValueChanged="@OnStatusChanged">
            <MudSelectItem Value="@("all")">All</MudSelectItem>
            <MudSelectItem Value="@("Active")">Active</MudSelectItem>
            <MudSelectItem Value="@("Inactive")">Inactive</MudSelectItem>
        </MudSelect>
    </div>
</MudPaper>

<MudGrid>
    @foreach (var c in _courses)
    {
        <MudItem xs="12" sm="6" lg="4">
            <MudCard Elevation="1" Class="rounded-xl h-100">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled">
                            @(c.Code?.Length > 0 ? c.Code[..1] : "C")
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1" Class="fw-bold">@c.Name</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@c.Code · @c.GradeLevel</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudChip Size="Size.Small" T="string" 
                                  Color="@(c.Status == CourseStatus.Active ? Color.Success : Color.Default)">
                            @c.Status
                        </MudChip>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3"
                             Style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                        @c.Description
                    </MudText>
                    <div class="d-flex gap-3 flex-wrap">
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption">@c.ActiveClassCount classes</MudText>
                        </div>
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption">@c.TotalEnrolledStudents students</MudText>
                        </div>
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption">@c.FeeCurrency @c.FeeAmount.ToString("N0")/mo</MudText>
                        </div>
                    </div>
                </MudCardContent>
                <MudCardActions>
                    <AuthorizeView Roles="Admin">
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" 
                                   OnClick="@(() => OpenEditDialog(c))">Edit</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" 
                                   OnClick="@(() => DeleteAsync(c))">Delete</MudButton>
                    </AuthorizeView>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@if (_loading)
{
    <MudGrid>
        @for (int i = 0; i < 6; i++)
        {
            <MudItem xs="12" sm="6" lg="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" Class="rounded-xl" />
            </MudItem>
        }
    </MudGrid>
}
else if (!_courses.Any())
{
    <div class="d-flex flex-column align-center pa-12">
        <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Style="font-size:4rem" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Class="mt-4" Color="Color.Secondary">No courses yet</MudText>
    </div>
}

<!-- Hidden table for server paging -->
<MudTable T="CourseDto" ServerData="@LoadData" @ref="_table" Hidden="true" />

@code {
    private MudTable<CourseDto> _table = null!;
    private List<CourseDto> _courses = new();
    private string _search = string.Empty;
    private string _statusFilter = "all";
    private bool _loading = true;
    private bool _isFirstLoad = true;

    protected override async Task OnInitializedAsync()
    {
        // Do NOT call RefreshCourses here
        await LoadInitialData();
    }

    private async Task LoadInitialData()
    {
        _loading = true;
        StateHasChanged();

        // Manual first load
        var url = $"api/courses?pageNumber=1&pageSize=50&search=&status=all";
        var r = await Api.GetAsync<PagedResult<CourseDto>>(url);

        _courses = r.Data?.Items?.ToList() ?? new();
        _loading = false;
        StateHasChanged();
    }

    private async Task<TableData<CourseDto>> LoadData(TableState state, CancellationToken token)
    {
        _loading = true;
        StateHasChanged();

        var url = $"api/courses?pageNumber={state.Page + 1}&pageSize=50" +
                  $"&search={Uri.EscapeDataString(_search)}" +
                  $"&status={_statusFilter}";

        var r = await Api.GetAsync<PagedResult<CourseDto>>(url);

        _courses = r.Data?.Items?.ToList() ?? new();
        _loading = false;

        return new TableData<CourseDto>
        {
            Items = _courses,
            TotalItems = r.Data?.TotalCount ?? 0
        };
    }

    private async Task RefreshCourses()
    {
        if (_table == null)
        {
            await LoadInitialData();
            return;
        }

        await _table.ReloadServerData();
        StateHasChanged();
    }

    private async Task OpenCreateDialog()
    {
        var d = await DialogService.ShowAsync<CourseFormDialog>("New Course",
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        if (!(await d.Result).Canceled)
            await RefreshCourses();
    }

    private async Task OpenEditDialog(CourseDto course)
    {
        var parameters = new DialogParameters { ["Course"] = course };

        var d = await DialogService.ShowAsync<CourseFormDialog>("Edit Course", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        if (!(await d.Result).Canceled)
            await RefreshCourses();
    }

    private async Task DeleteAsync(CourseDto c)
    {
        var ok = await DialogService.ShowMessageBox(
            "Delete Course",
            $"Delete '{c.Name}'? This will also remove all associated classes.",
            yesText: "Delete", noText: "Cancel");

        if (ok != true) return;

        var r = await Api.DeleteAsync($"api/courses/{c.Id}");
        
        if (r.Success)
        {
            Snackbar.Add("Course deleted successfully.", Severity.Success);
            await RefreshCourses();
        }
        else
        {
            Snackbar.Add(r.Error ?? "Failed to delete course.", Severity.Error);
        }
    }

    private async Task OnStatusChanged(string newValue)
    {
        _statusFilter = newValue;
        await RefreshCourses();
    }
}