@page "/my-classes"
@using Microsoft.AspNetCore.Authorization
@using TMS.Application.Common
@using TMS.Application.DTOs.Course
@using TMS.Application.DTOs.Student
@using TMS.Web.Auth
@using TMS.Web.Services
@attribute [Authorize(Roles = "Student,Parent")]
@inject ApiClient Api
@inject TmsAuthStateProvider AuthProvider
@using MudBlazor

<PageTitle>My Classes – TMS</PageTitle>

<MudText Typo="Typo.h5" Class="fw-bold mb-1">My Classes</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
    Your current enrolments and timetable
</MudText>

@if (_loading)
{
    <MudGrid>
        @for (int i = 0; i < 3; i++)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="180px" Class="rounded-xl" />
            </MudItem>
        }
    </MudGrid>
}
else if (_classes.Any())
{
    <MudGrid>
        @foreach (var cls in _classes)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="1" Class="rounded-xl h-100">
                    <div style="height:8px;background:var(--mud-palette-primary)" class="rounded-t-xl"></div>
                    <MudCardContent>
                        <MudText Typo="Typo.subtitle1" Class="fw-bold">@cls.Name</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            @cls.CourseName
                        </MudText>

                        <div class="d-flex flex-column gap-2">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Person"
                                         Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@cls.TutorName</MudText>
                            </div>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule"
                                         Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">
                                    @cls.DayOfWeek · @cls.StartTime.ToString("HH:mm") – @cls.EndTime.ToString("HH:mm")
                                </MudText>
                            </div>
                            @if (!string.IsNullOrEmpty(cls.Room))
                            {
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Room"
                                             Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2">Room @cls.Room</MudText>
                                </div>
                            }
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday"
                                         Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">
                                    From @cls.StartDate.ToString("dd MMM yyyy")
                                </MudText>
                            </div>
                        </div>
                    </MudCardContent>
                    <MudCardActions>
                        <MudChip Size="Size.Small" Color="Color.Success" T="string">Active</MudChip>
                        <MudSpacer />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @cls.EnrolledCount / @cls.MaxCapacity students
                        </MudText>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}
else
{
    <div class="d-flex flex-column align-center pa-12">
        <MudIcon Icon="@Icons.Material.Filled.EventBusy"
                 Style="font-size:4rem" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Class="mt-4" Color="Color.Secondary">
            You are not enrolled in any classes
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Contact admin to enrol you in a class
        </MudText>
    </div>
}

@code {
    private List<ClassDto> _classes = new();
    private bool           _loading = true;
    private Guid?          _studentId;

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthProvider.GetCurrentUserAsync();
        if (user is null) return;

        // Find the student record linked to this user
        var sr = await Api.GetAsync<PagedResult<StudentSummaryDto>>("api/students?pageSize=200");
        // NOTE: in a real app you'd have a GET /api/students/me endpoint
        // For now we load all and match by userId from the JWT
        _loading = false;
        // Placeholder — attach to student portal user endpoint when built
        _classes = new();
    }
}
