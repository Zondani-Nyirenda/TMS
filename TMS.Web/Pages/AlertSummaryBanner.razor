@using MudBlazor

<div class="alert-banner">
    <div class="alert-banner-glow"></div>
    <div class="d-flex align-center justify-space-between flex-wrap" style="gap:12px;">
        <div class="d-flex align-center gap-3">
            <div class="alert-banner-icon">
                <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Style="font-size:22px;color:#818CF8;" />
            </div>
            <div>
                <MudText Typo="Typo.caption" Class="alert-banner-label">
                    TERM SUMMARY · REQUIRES ATTENTION
                </MudText>
                <MudText Typo="Typo.subtitle1" Class="alert-banner-title">
                    47 overdue fee accounts · 6 exam results pending · 18 students below 75% attendance
                </MudText>
                <MudText Typo="Typo.caption" Class="alert-banner-sub">
                    Last updated 5 min ago · Term 2, Week 8 of 12
                </MudText>
            </div>
        </div>
        <div class="d-flex align-center gap-2">
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       Style="color:#818CF8;font-size:12px;font-weight:600;text-transform:none;border-radius:8px;">
                View All Alerts
            </MudButton>
            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       Class="alert-banner-btn">
                Take Action
            </MudButton>
        </div>
    </div>
</div>

@code { }
