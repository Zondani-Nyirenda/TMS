@inject ApiClient Api
@inject ISnackbar Snackbar
@using MudBlazor
@using TMS.Application.DTOs.StudyMaterial
@using TMS.Web.Services

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(SubjectId.HasValue ? "Edit Subject" : "New Subject")
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_name"
                              Label="Subject Name *"
                              Variant="Variant.Outlined"
                              FullWidth="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_description"
                              Label="Description"
                              Variant="Variant.Outlined"
                              Lines="3"
                              FullWidth="true" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_iconEmoji"
                              Label="Icon Emoji"
                              Placeholder="e.g. 📘"
                              Variant="Variant.Outlined"
                              FullWidth="true" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_colorHex"
                              Label="Color (Hex)"
                              Placeholder="#4F46E5"
                              Variant="Variant.Outlined"
                              FullWidth="true" />
            </MudItem>
            <MudItem xs="6">
                <MudNumericField @bind-Value="_sortOrder"
                                 Label="Sort Order"
                                 Variant="Variant.Outlined"
                                 Min="0"
                                 FullWidth="true" />
            </MudItem>
            <MudItem xs="6">
                <MudSwitch @bind-Value="_isActive"
                           Label="Active"
                           Color="Color.Primary" />
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="SubmitAsync"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="_saving">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(SubjectId.HasValue ? "Save Changes" : "Create Subject")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Guid? SubjectId { get; set; }
    [Parameter] public string ExistingName { get; set; } = string.Empty;
    [Parameter] public string? ExistingDescription { get; set; }
    [Parameter] public string? ExistingIconEmoji { get; set; }
    [Parameter] public string? ExistingColorHex { get; set; }
    [Parameter] public int ExistingSortOrder { get; set; }
    [Parameter] public bool ExistingIsActive { get; set; } = true;

    private string _name = string.Empty;
    private string? _description;
    private string? _iconEmoji;
    private string? _colorHex;
    private int _sortOrder;
    private bool _isActive = true;
    private bool _saving;

    protected override void OnParametersSet()
    {
        _name = ExistingName;
        _description = ExistingDescription;
        _iconEmoji = ExistingIconEmoji;
        _colorHex = ExistingColorHex;
        _sortOrder = ExistingSortOrder;
        _isActive = ExistingIsActive;
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            Snackbar.Add("Subject name is required.", Severity.Warning);
            return;
        }

        _saving = true;

        if (SubjectId.HasValue)
        {
            var result = await Api.PutAsync<SubjectDto>(
                $"api/subjects/{SubjectId}",
                new UpdateSubjectRequest
                {
                    Name = _name,
                    Description = _description,
                    IconEmoji = _iconEmoji,
                    ColorHex = _colorHex,
                    SortOrder = _sortOrder,
                    IsActive = _isActive
                });

            if (result.Success)
            {
                Snackbar.Add("Subject updated.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
                Snackbar.Add(result.Error ?? "Update failed.", Severity.Error);
        }
        else
        {
            var result = await Api.PostAsync<SubjectDto>(
                "api/subjects",
                new CreateSubjectRequest
                {
                    Name = _name,
                    Description = _description,
                    IconEmoji = _iconEmoji,
                    ColorHex = _colorHex,
                    SortOrder = _sortOrder,
                    IsActive = _isActive
                });

            if (result.Success)
            {
                Snackbar.Add("Subject created.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
                Snackbar.Add(result.Error ?? "Create failed.", Severity.Error);
        }

        _saving = false;
    }

    private void Cancel() => MudDialog.Cancel();
}