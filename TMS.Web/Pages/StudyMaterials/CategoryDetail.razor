@page "/study-materials/{SubjectId:guid}/categories/{CategoryId:guid}"
@inject ApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using MudBlazor
@using TMS.Application.DTOs.StudyMaterial
@using TMS.Domain.Enums
@using TMS.Web.Services
@using TMS.Application.Common

<PageTitle>@_categoryName – TMS</PageTitle>

<!-- Breadcrumb -->
<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 px-0" />

<!-- Toolbar -->
<div class="d-flex align-center justify-space-between mb-4 flex-wrap gap-3">
    <div>
        <MudText Typo="Typo.h5" Class="fw-bold">@_categoryName</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @_totalCount material@(_totalCount == 1 ? "" : "s")
        </MudText>
    </div>

    <AuthorizeView Roles="Admin,Tutor">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Upload"
                   OnClick="OpenUploadDialog">
            Upload Material
        </MudButton>
    </AuthorizeView>
</div>

<!-- Search + Filter bar -->
<MudPaper Elevation="1" Class="pa-3 mb-4 rounded-xl">
    <div class="d-flex align-center gap-3 flex-wrap">
        <MudTextField @bind-Value="_search"
                      Placeholder="Search materials…"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Clearable="true"
                      Class="flex-grow-1"
                      DebounceInterval="400"
                      OnDebounceIntervalElapsed="LoadAsync"
                      OnClearButtonClick="@(() => { _search = string.Empty; LoadAsync(); })" />

        <MudSelect @bind-Value="_typeFilter"
                   @bind-Value:after="LoadAsync"
                   Label="Type" Variant="Variant.Outlined"
                   Style="min-width:140px" Clearable="true">
            @foreach (MaterialType type in Enum.GetValues<MaterialType>())
            {
                <MudSelectItem Value="@((MaterialType?)type)">@type</MudSelectItem>
            }
        </MudSelect>

        <MudTextField @bind-Value="_yearFilter"
                      Label="Year" Variant="Variant.Outlined"
                      Style="min-width:100px"
                      @bind-Value:after="LoadAsync" />
    </div>
</MudPaper>

<!-- Loading -->
@if (_loading)
{
    <MudGrid>
        @for (int i = 0; i < 6; i++)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-xl">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="140px" />
                    <MudSkeleton Class="mt-2" />
                    <MudSkeleton Width="70%" />
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}
else if (!_materials.Any())
{
    <MudPaper Elevation="1" Class="pa-12 rounded-xl d-flex flex-column align-center">
        <MudIcon Icon="@Icons.Material.Filled.FolderOpen"
                 Style="font-size:4rem" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Class="mt-4" Color="Color.Secondary">
            No materials yet
        </MudText>
    </MudPaper>
}
else
{
    <MudGrid>
        @foreach (var m in _materials)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-4 rounded-xl" Style="height:100%">

                    <!-- Thumbnail or type icon -->
                    @if (!string.IsNullOrWhiteSpace(m.ThumbnailUrl))
                    {
                        <MudImage Src="@m.ThumbnailUrl"
                                  Alt="@m.Title"
                                  Class="rounded-lg mb-3"
                                  Style="width:100%;height:140px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="d-flex align-center justify-center rounded-lg mb-3"
                             style="height:80px;background:#f3f4f6">
                            <MudText Style="font-size:2.5rem">
                                @GetTypeEmoji(m.Type)
                            </MudText>
                        </div>
                    }

                    <!-- Title & chips -->
                    <MudText Typo="Typo.subtitle1" Class="fw-bold">@m.Title</MudText>

                    @if (!string.IsNullOrWhiteSpace(m.Description))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary"
                                 Class="mt-1"
                                 Style="overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
                            @m.Description
                        </MudText>
                    }

                    <div class="d-flex gap-2 flex-wrap mt-2">
                        <MudChip Size="Size.Small" Color="Color.Info" T="string">
                            @m.Type
                        </MudChip>
                        @if (m.AcademicYear.HasValue)
                        {
                            <MudChip Size="Size.Small" Color="Color.Default" T="string">
                                @m.AcademicYear
                            </MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(m.GradeLevel))
                        {
                            <MudChip Size="Size.Small" Color="Color.Default" T="string">
                                @m.GradeLevel
                            </MudChip>
                        }
                    </div>

                    <!-- Video progress bar -->
                    @if (m.Type == MaterialType.VideoLesson && m.VideoProgressPercentage.HasValue)
                    {
                        <MudProgressLinear Value="@m.VideoProgressPercentage.Value"
                                           Color="Color.Primary"
                                           Class="mt-2"
                                           Rounded="true"
                                           Size="Size.Small" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @m.VideoProgressPercentage.Value.ToString("F0")% watched
                        </MudText>
                    }

                    <!-- Actions -->
                    <div class="d-flex gap-1 mt-3 flex-wrap">
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Visibility"
                                   OnClick="@(() => Nav.NavigateTo($"/study-materials/view/{m.Id}"))">
                            View
                        </MudButton>

                        @if (m.AllowDownload)
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.Download"
                                       OnClick="@(() => DownloadAsync(m.Id, m.Title))">
                                Download
                            </MudButton>
                        }

                        <MudTooltip Text="@(m.IsBookmarked ? "Remove bookmark" : "Bookmark")">
                            <MudIconButton Icon="@(m.IsBookmarked
                                            ? Icons.Material.Filled.Bookmark
                                            : Icons.Material.Outlined.BookmarkBorder)"
                                           Color="@(m.IsBookmarked ? Color.Warning : Color.Default)"
                                           Size="Size.Small"
                                           OnClick="@(() => ToggleBookmarkAsync(m))" />
                        </MudTooltip>

                        <AuthorizeView Roles="Admin,Tutor">
                            <MudTooltip Text="Delete">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="@(() => DeleteMaterialAsync(m.Id, m.Title))" />
                            </MudTooltip>
                        </AuthorizeView>
                    </div>

                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <!-- Pagination -->
    <div class="d-flex justify-center mt-6">
        <MudPagination Count="@_totalPages"
                       Selected="@_page"
                       SelectedChanged="OnPageChanged"
                       Color="Color.Primary" />
    </div>
}

@code {
    [Parameter] public Guid SubjectId { get; set; }
    [Parameter] public Guid CategoryId { get; set; }

    private List<StudyMaterialSummaryDto> _materials = new();
    private string _categoryName = "Category";
    private string _subjectName = "Subject";
    private bool _loading = true;
    private string _search = string.Empty;
    private MaterialType? _typeFilter;
    private string? _yearFilter;
    private int _page = 1;
    private int _pageSize = 12;
    private int _totalCount = 0;
    private int _totalPages => (int)Math.Ceiling(_totalCount / (double)_pageSize);

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new("Study Materials", "/study-materials"),
        new(_subjectName, $"/study-materials/{SubjectId}"),
        new(_categoryName, null, disabled: true)
    };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;

        // Load category name for breadcrumb
        var catResult = await Api.GetAsync<MaterialCategoryDto>(
            $"api/subjects/categories/{CategoryId}");
        if (catResult.Success && catResult.Data is not null)
        {
            _categoryName = catResult.Data.Name;
            _subjectName = catResult.Data.SubjectName;
        }

        // Build query
        var url = $"api/study-materials?categoryId={CategoryId}" +
                  $"&pageNumber={_page}&pageSize={_pageSize}" +
                  $"&search={Uri.EscapeDataString(_search ?? string.Empty)}";

        if (_typeFilter.HasValue)
            url += $"&type={_typeFilter}";

        if (!string.IsNullOrWhiteSpace(_yearFilter) &&
            int.TryParse(_yearFilter, out var year))
            url += $"&academicYear={year}";

        var result = await Api.GetAsync<PagedResult<StudyMaterialSummaryDto>>(url);
        if (result.Success && result.Data is not null)
        {
            _materials = result.Data.Items.ToList();
            _totalCount = result.Data.TotalCount;
        }

        _loading = false;
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task DownloadAsync(Guid id, string title)
    {
        var result = await Api.PostAsync<object>($"api/study-materials/{id}/download", new { });
        if (result.Success)
            Snackbar.Add($"Downloading '{title}'…", Severity.Info);
        else
            Snackbar.Add(result.Error ?? "Download failed.", Severity.Error);
    }

    private async Task ToggleBookmarkAsync(StudyMaterialSummaryDto material)
    {
        if (material.IsBookmarked)
        {
            var ok = await Api.DeleteAsync($"api/study-materials/{material.Id}/bookmark");
            if (ok.Success)
            {
                material.IsBookmarked = false;
                Snackbar.Add("Bookmark removed.", Severity.Info);
            }
        }
        else
        {
            var result = await Api.PostAsync<BookmarkDto>(
                $"api/study-materials/{material.Id}/bookmark", new { });
            if (result.Success)
            {
                material.IsBookmarked = true;
                Snackbar.Add("Bookmarked!", Severity.Success);
            }
        }
        StateHasChanged();
    }

    private async Task DeleteMaterialAsync(Guid id, string title)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Confirm Delete", $"Delete '{title}'?",
            yesText: "Delete", noText: "Cancel");

        if (confirmed != true) return;

        var ok = await Api.DeleteAsync($"api/study-materials/{id}");
        if (ok.Success)
        {
            Snackbar.Add($"'{title}' deleted.", Severity.Success);
            await LoadAsync();
        }
        else
            Snackbar.Add("Delete failed.", Severity.Error);
    }

    private async Task OpenUploadDialog()
    {
        var parameters = new DialogParameters { ["CategoryId"] = CategoryId };
        var dialog = await DialogService.ShowAsync<UploadMaterialDialog>(
            "Upload Material", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private static string GetTypeEmoji(MaterialType type) => type switch
    {
        MaterialType.Book          => "📚",
        MaterialType.PastPaper     => "📝",
        MaterialType.VideoLesson   => "🎥",
        MaterialType.Notes         => "📄",
        MaterialType.Assignment    => "✏️",
        MaterialType.MarkingScheme => "✅",
        _                          => "📁"
    };
}
