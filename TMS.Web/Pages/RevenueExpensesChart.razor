@using MudBlazor
@inject IJSRuntime JS

<MudPaper Style="background:#13151F;border:1px solid #1E2130;border-radius:12px;padding:20px;">
    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.subtitle1"
                 Style="color:#F9FAFB;font-weight:700;font-size:14px;letter-spacing:-0.2px;">
            Revenue vs Expenses — 2025
        </MudText>
        <div class="d-flex align-center gap-3">
            <div class="d-flex align-center gap-1">
                <div style="width:8px;height:8px;border-radius:2px;background:#6366F1;"></div>
                <MudText Typo="Typo.caption" Style="color:#9CA3AF;font-size:11px;">Revenue</MudText>
            </div>
            <div class="d-flex align-center gap-1">
                <div style="width:8px;height:8px;border-radius:2px;background:#EF4444;"></div>
                <MudText Typo="Typo.caption" Style="color:#9CA3AF;font-size:11px;">Expenses</MudText>
            </div>
            <div class="d-flex align-center gap-1">
                <div style="width:8px;height:8px;border-radius:2px;background:#10B981;"></div>
                <MudText Typo="Typo.caption" Style="color:#9CA3AF;font-size:11px;">Profit</MudText>
            </div>
        </div>
    </div>

    <div style="position:relative;height:200px;">
        <canvas id="revenueChart"></canvas>
    </div>
</MudPaper>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initRevenueChart");
        }
    }
}
