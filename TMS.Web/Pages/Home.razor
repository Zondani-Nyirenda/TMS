@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject NavigationManager Nav
@inject TMS.Web.Auth.TmsAuthStateProvider AuthProvider

@code {
    protected override async Task OnInitializedAsync()
    {
        var user = await AuthProvider.GetCurrentUserAsync();
        var role = user?.Role.ToString() ?? "Admin";

        var destination = role switch
        {
            "Tutor" => "/tutor/dashboard",
            "Student" => "/student/dashboard",
            _ => "/admin/dashboard"
        };

        Nav.NavigateTo(destination, forceLoad: false);
    }
}