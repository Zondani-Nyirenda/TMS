@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject NavigationManager Nav

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
                <Authorizing>
                    <div style="display:flex;justify-content:center;align-items:center;
                        height:100vh;background:#0B0D14;flex-direction:column;gap:16px;">
                        <div style="width:48px;height:48px;background:linear-gradient(135deg,#6366F1,#8B5CF6);
                            border-radius:12px;display:flex;align-items:center;justify-content:center;">
                            <MudIcon Icon="@Icons.Material.Filled.School" Style="color:#fff;" />
                        </div>
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="width:160px;" />
                        <MudText Typo="Typo.caption" Style="color:#6B7280;">Verifying session...</MudText>
                    </div>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <div class="d-flex flex-column align-center justify-center pa-10">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.h5" Class="mt-4">Page Not Found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Sorry, there's nothing at this address.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" href="/" Class="mt-4">
                        Back Home
                    </MudButton>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>