@using MudBlazor
@using TMS.Application.DTOs.Content
@using TMS.Domain.Enums
@using TMS.Web.Services
@inject ApiClient Api
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Folder" Class="mr-2" />
            @(Module is null ? "Add Module" : "Edit Module")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_valid">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_title" Label="Module Title"
                                  Variant="Variant.Outlined" Required="true"
                                  Placeholder="e.g. Week 1 – Introduction" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_description" Label="Description (optional)"
                                  Variant="Variant.Outlined" Lines="2"
                                  Placeholder="Brief overview of this module's content" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField @bind-Value="_sortOrder" Label="Display Order"
                                     Variant="Variant.Outlined" Min="0"
                                     HelperText="Lower number appears first" />
                </MudItem>
                @if (Module is not null)
                {
                    <MudItem xs="12" sm="6">
                        <MudSelect @bind-Value="_status" Label="Status" Variant="Variant.Outlined">
                            @foreach (var s in Enum.GetValues<ContentModuleStatus>())
                            {
                                <MudSelectItem Value="@s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SaveAsync" Disabled="_saving">
            @(_saving ? "Saving…" : (Module is null ? "Create" : "Save"))
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid              CourseId { get; set; }
    [Parameter] public ContentModuleDto? Module   { get; set; }

    private MudForm _form  = null!;
    private bool    _valid = false, _saving = false;
    private string  _title = string.Empty, _description = string.Empty;
    private int     _sortOrder = 0;
    private ContentModuleStatus _status = ContentModuleStatus.Draft;

    protected override void OnParametersSet()
    {
        if (Module is null) return;
        _title       = Module.Title;
        _description = Module.Description ?? string.Empty;
        _sortOrder   = Module.SortOrder;
        _status      = Module.Status;
    }

    private async Task SaveAsync()
    {
        await _form.Validate();
        if (!_valid) return;
        _saving = true;

        ApiResult<ContentModuleDto> result;

        if (Module is null)
        {
            result = await Api.PostAsync<ContentModuleDto>("api/content/modules",
                new CreateContentModuleRequest
                {
                    CourseId    = CourseId,
                    Title       = _title.Trim(),
                    Description = string.IsNullOrWhiteSpace(_description) ? null : _description.Trim(),
                    SortOrder   = _sortOrder
                });
        }
        else
        {
            result = await Api.PutAsync<ContentModuleDto>($"api/content/modules/{Module.Id}",
                new UpdateContentModuleRequest
                {
                    Title       = _title.Trim(),
                    Description = string.IsNullOrWhiteSpace(_description) ? null : _description.Trim(),
                    SortOrder   = _sortOrder,
                    Status      = _status
                });
        }

        if (result.Success)
            MudDialog.Close(DialogResult.Ok(result.Data));
        else
            Snackbar.Add(result.Error ?? "Save failed.", Severity.Error);

        _saving = false;
    }
}
