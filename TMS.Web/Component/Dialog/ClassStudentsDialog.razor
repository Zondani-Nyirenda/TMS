@using MudBlazor
@using TMS.Application.DTOs.Student
@using TMS.Web.Services
@inject ApiClient Api

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
            @ClassName – Enrolled Students
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_students.Any())
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                @_students.Count student(s) enrolled
            </MudText>
            <MudList Dense="true" DisablePadding="true" T="string">
                @foreach (var s in _students)
                {
                    <MudListItem>
                        <div class="d-flex align-center gap-3">
                            <MudAvatar Color="Color.Primary" Size="Size.Small">
                                @s.FullName[..1]
                            </MudAvatar>
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.body2" Class="fw-semibold">@s.FullName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @s.StudentNumber · @s.Email
                                </MudText>
                            </div>
                            <MudChip Size="Size.Small"
                                     Color="@(s.IsActive ? Color.Success : Color.Default)">
                                @(s.IsActive ? "Active" : "Inactive")
                            </MudChip>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        }
        else
        {
            <div class="d-flex flex-column align-center pa-6">
                <MudIcon Icon="@Icons.Material.Filled.PersonOff"
                         Style="font-size:3rem" Color="Color.Secondary" />
                <MudText Color="Color.Secondary" Class="mt-2">No students enrolled yet.</MudText>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Close())">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Guid   ClassId   { get; set; }
    [Parameter] public string ClassName { get; set; } = string.Empty;

    private List<StudentSummaryDto> _students = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var r = await Api.GetAsync<List<StudentSummaryDto>>($"api/classes/{ClassId}/students");
        _students = r.Data ?? new();
        _loading  = false;
    }
}
